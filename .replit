run = "npm install && npm run dev"
language = "nodejs"
modules = ["python-3.11", "nodejs-20"]

[packager]
language = "nodejs"

  [packager.features]
  packageSearch = true
  guessImports = true
  enabledForHosting = false

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 3000
externalPort = 3000

[agent]
expertMode = true
integrations = ["github:1.0.0"]
