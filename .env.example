VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ANTHROPIC_API_KEY is NOT needed in .env anymore.
# The AI paperwork scanner now uses a Supabase edge function.
# Set the key in your Supabase project secrets instead:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxx
